KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_rsa_private_key_here
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Auto-Sell Bot (bot.py) — Dual-Mode: Favorite + Longshot ---
#
# The bot automatically detects the mode from avg_buy:
#   avg_buy <  LONGSHOT_THRESHOLD  →  LONGSHOT mode  (price-based TPs, loose SL)
#   avg_buy >= LONGSHOT_THRESHOLD  →  FAVORITE mode  (%-based TPs, three-layer SL)

# Price threshold in cents that separates favorites from longshots (default: 30¢)
LONGSHOT_THRESHOLD=30

# ── FAVORITE mode — Take-Profit (% based) ────────────────────────────────────
TP1_PROFIT_PCT=25
TP1_SELL_RATIO=0.30

TP2_PROFIT_PCT=50
TP2_SELL_RATIO=0.40

TP3_PROFIT_PCT=75
TP3_PRICE_TARGET=92

# ── FAVORITE mode — Stop-Loss (three layers) ─────────────────────────────────
# Soft stop: sell 50% when loss reaches -20% (fires once, then hard stop arms)
SOFT_SL_PCT=-20
SOFT_SL_RATIO=0.50

# Hard stop: sell ALL when loss reaches -35%  (= avg_buy × 0.65, dynamic)
HARD_SL_PCT=-35

# Trailing stop: once peak profit (on original position) exceeds a $ threshold,
# set a floor above entry to lock in a fraction of the peak gain.
#   Peak >= $2  →  floor = entry + 30% of peak gain per contract
#   Peak >= $4  →  floor = entry + 50% of peak gain per contract
TRAIL_SL_THRESHOLD_1=2.0
TRAIL_SL_RATIO_1=0.30
TRAIL_SL_THRESHOLD_2=4.0
TRAIL_SL_RATIO_2=0.50

# ── LONGSHOT mode — single clean exit ────────────────────────────────────────
# When a longshot reaches ~57¢ (coin-flip zone) the original mispricing is gone.
# Sell everything there and redeploy. No partial exits — they kill the best positions.
LS_EXIT_PRICE=57

# Single hard stop. Longshots are volatile — just accept the loss and move on.
LS_HARD_SL_PCT=-60

# ── General ──────────────────────────────────────────────────────────────────
POLL_INTERVAL=10

# DRY_RUN=true  → logs what WOULD happen, does NOT place real orders (safe default)
# DRY_RUN=false → places real sell orders on Kalshi
DRY_RUN=true

# --- Matchstat API (via RapidAPI) ---
# Get your key at: https://rapidapi.com/jjrm365-kIFr3Nx_odV/api/tennis-api-atp-wta-itf
MATCHSTAT_API_KEY=your_rapidapi_key_here
# Endpoint to call — update after checking your RapidAPI subscription
MATCHSTAT_PREDICTIONS_ENDPOINT=/tennis/
# Minimum win probability from Matchstat to confirm a BUY signal (0.0–1.0)
MATCHSTAT_MIN_WIN_PCT=0.65

# --- Automation ---
# DRY_RUN=true  → logs intended orders without placing them (safe default)
# DRY_RUN=false → places real limit orders on Kalshi (only after testing dry-run)
DRY_RUN=true
# Number of contracts per limit order (each contract = $1 max payout)
CONTRACTS_PER_TRADE=50
# Hard cap per order regardless of CONTRACTS_PER_TRADE
MAX_CONTRACTS_PER_ORDER=100
# How often to run the automation cycle (minutes)
AUTOMATION_INTERVAL_MINUTES=10
# Set to true to start the scheduler automatically on server boot
AUTOMATION_AUTOSTART=false
