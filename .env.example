KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_rsa_private_key_here
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# --- Auto-Sell Bot (bot.py) — Tiered Take-Profit + Dynamic Stop-Loss ---

# ── Take-Profit ──────────────────────────────────────────────────────────────
# Level 1: sell 30% of initial contracts when profit >= 25%
TP1_PROFIT_PCT=25
TP1_SELL_RATIO=0.30

# Level 2: sell 40% of initial contracts when profit >= 50% (fires only after TP1)
TP2_PROFIT_PCT=50
TP2_SELL_RATIO=0.40

# Level 3: sell ALL remaining when profit >= 75% OR price reaches 92¢
TP3_PROFIT_PCT=75
TP3_PRICE_TARGET=92

# ── Stop-Loss (three layers) ─────────────────────────────────────────────────
# SOFT STOP: sell 50% of remaining contracts when loss reaches -20% (fires once)
SOFT_SL_PCT=-20
SOFT_SL_RATIO=0.50

# HARD STOP: sell ALL remaining when loss reaches -35%
# This is dynamic: equivalent to price falling to avg_buy × 0.65 (scales with entry)
HARD_SL_PCT=-35

# TRAILING STOP: once the position has been sufficiently profitable, lock in a floor.
# Peak profit is measured on the original (initial) position size.
#   If peak profit >= $2  → floor = entry + 30% of peak gain per contract
#   If peak profit >= $4  → floor = entry + 50% of peak gain per contract
# When current bid falls below the floor → sell ALL remaining contracts.
TRAIL_SL_THRESHOLD_1=2.0
TRAIL_SL_RATIO_1=0.30
TRAIL_SL_THRESHOLD_2=4.0
TRAIL_SL_RATIO_2=0.50

# ── General ──────────────────────────────────────────────────────────────────
# Seconds between each scan of your positions
POLL_INTERVAL=10

# DRY_RUN=true  → logs what WOULD happen, does NOT place real orders (safe default)
# DRY_RUN=false → places real sell orders on Kalshi
DRY_RUN=true

# --- Matchstat API (via RapidAPI) ---
# Get your key at: https://rapidapi.com/jjrm365-kIFr3Nx_odV/api/tennis-api-atp-wta-itf
MATCHSTAT_API_KEY=your_rapidapi_key_here
# Endpoint to call — update after checking your RapidAPI subscription
MATCHSTAT_PREDICTIONS_ENDPOINT=/tennis/
# Minimum win probability from Matchstat to confirm a BUY signal (0.0–1.0)
MATCHSTAT_MIN_WIN_PCT=0.65

# --- Automation ---
# DRY_RUN=true  → logs intended orders without placing them (safe default)
# DRY_RUN=false → places real limit orders on Kalshi (only after testing dry-run)
DRY_RUN=true
# Number of contracts per limit order (each contract = $1 max payout)
CONTRACTS_PER_TRADE=50
# Hard cap per order regardless of CONTRACTS_PER_TRADE
MAX_CONTRACTS_PER_ORDER=100
# How often to run the automation cycle (minutes)
AUTOMATION_INTERVAL_MINUTES=10
# Set to true to start the scheduler automatically on server boot
AUTOMATION_AUTOSTART=false
